
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OCPP Dashboard</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:system-ui,sans-serif;background:#0f172a;color:#e2e8f0;min-height:100vh}

    /* ── Header ─────────────────────────────────────────── */
    header{background:#1e293b;padding:.875rem 1.5rem;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #334155;gap:.75rem;flex-wrap:wrap;position:sticky;top:0;z-index:50}
    header h1{font-size:1.1rem;font-weight:700;color:#38bdf8}
    .header-right{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap}

    /* ── Layout ─────────────────────────────────────────── */
    main{padding:1.5rem;max-width:1600px;margin:0 auto}
    .stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:.75rem;margin-bottom:1.5rem}
    .stat-card{background:#1e293b;border:1px solid #334155;border-radius:10px;padding:1rem;text-align:center}
    .stat-card .val{font-size:1.75rem;font-weight:700;color:#38bdf8}
    .stat-card .lbl{font-size:.75rem;color:#94a3b8;margin-top:3px}
    .section-title{font-size:.8rem;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:.06em;margin-bottom:.75rem}
    .chart-card{background:#1e293b;border:1px solid #334155;border-radius:10px;padding:1.25rem;margin-bottom:1.5rem}
    .chart-card canvas{max-height:200px}

    /* ── Charger cards ───────────────────────────────────── */
    .chargers-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(380px,1fr));gap:1rem;margin-bottom:1.5rem}
    .charger-card{background:#1e293b;border:1px solid #334155;border-radius:12px;padding:1.25rem;transition:border-color .25s}
    .charger-card.connected{border-color:#1d4ed8}
    .ch-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:.625rem}
    .ch-id{font-weight:700;font-size:.95rem;display:flex;align-items:center;gap:6px;flex-wrap:wrap}
    .ch-meta{font-size:.72rem;color:#94a3b8;margin-top:2px}
    .ch-ip{font-size:.68rem;color:#475569;margin-top:1px;font-family:monospace}
    .ch-cfg{font-size:.68rem;color:#64748b;margin-top:2px}

    /* ── Badges ─────────────────────────────────────────── */
    .badge{font-size:.7rem;font-weight:600;padding:2px 9px;border-radius:999px;white-space:nowrap}
    .b-available{background:#166534;color:#86efac}
    .b-charging{background:#1e3a8a;color:#93c5fd}
    .b-faulted{background:#7f1d1d;color:#fca5a5}
    .b-offline{background:#374151;color:#9ca3af}
    .b-preparing{background:#78350f;color:#fcd34d}
    .b-unavailable{background:#374151;color:#9ca3af}
    .b-finishing{background:#4c1d95;color:#c4b5fd}
    .b-reserved{background:#1e3a5f;color:#7dd3fc}
    .b-suspendedev,.b-suspendedevse{background:#374151;color:#9ca3af}

    /* ── Connection bar ──────────────────────────────────── */
    .conn-bar{display:flex;align-items:center;gap:6px;font-size:.72rem;margin-bottom:.625rem;padding:4px 8px;border-radius:6px}
    .conn-bar.on{background:#052e16;color:#86efac}
    .conn-bar.off{background:#1c0a0a;color:#fca5a5}
    .conn-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
    .conn-dot.on{background:#86efac}
    .conn-dot.off{background:#fca5a5}

    /* ── Metrics ─────────────────────────────────────────── */
    .metrics-grid{display:grid;grid-template-columns:1fr 1fr;gap:.5rem;margin-bottom:.625rem}
    .metric-box{background:#0f172a;border-radius:8px;padding:.625rem;text-align:center;transition:border .2s;border:1px solid transparent}
    .metric-box.power-cut{border-color:#7f1d1d}
    .metric-lbl{font-size:.62rem;color:#64748b;text-transform:uppercase;letter-spacing:.04em;margin-bottom:2px}
    .metric-val{font-size:1.05rem;font-weight:700}
    .metric-sub{font-size:.68rem;color:#64748b;margin-top:1px}

    /* ── Connectors ──────────────────────────────────────── */
    .connectors{display:flex;gap:.375rem;flex-wrap:wrap;margin-bottom:.625rem}
    .connector{background:#0f172a;border:1px solid #334155;border-radius:7px;padding:.4rem .625rem;font-size:.75rem;min-width:90px}
    .connector .cl{font-size:.65rem;color:#64748b}
    .connector .cv{font-weight:600;margin-top:1px}
    .total-badge{font-size:.72rem;color:#94a3b8;padding:3px 8px;background:#0f172a;border-radius:5px;display:inline-block;margin-bottom:.5rem}
    .hb-time{font-size:.68rem;color:#475569;margin-bottom:.75rem}
    .tx-info{font-size:.68rem;color:#64748b;margin-bottom:.5rem;padding:3px 8px;background:#0f172a;border-radius:5px;display:inline-block}
    .tx-info.active{color:#93c5fd;background:#1e3a8a22;border:1px solid #1e3a8a}

    /* ── Buttons ─────────────────────────────────────────── */
    .actions{display:flex;gap:.375rem;flex-wrap:wrap;margin-bottom:.375rem}
    .actions-row2{display:flex;gap:.375rem;flex-wrap:wrap}
    .btn{padding:5px 12px;border-radius:7px;border:none;font-size:.78rem;font-weight:600;cursor:pointer;transition:opacity .15s,transform .1s}
    .btn:hover:not(:disabled){opacity:.82}
    .btn:active:not(:disabled){transform:scale(.97)}
    .btn:disabled{opacity:.3;cursor:not-allowed}
    .btn-start{background:#0284c7;color:#fff}
    .btn-stop{background:#dc2626;color:#fff}
    .btn-cut{background:#7f1d1d;color:#fca5a5}
    .btn-restore{background:#166534;color:#86efac}
    .btn-reset{background:#4b5563;color:#fff}
    .btn-avail{background:#065f46;color:#6ee7b7}
    .btn-unavail{background:#7c3aed;color:#ddd6fe}
    .btn-unlock{background:#92400e;color:#fde68a}
    .btn-cfg{background:#0f3460;color:#7dd3fc}
    .btn-edit{background:#1e3a8a;color:#93c5fd}
    .btn-add{background:#0284c7;color:#fff;font-size:.82rem}
    .btn-detect{background:#334155;color:#94a3b8}
    .btn-cancel{background:#374151;color:#fff}
    .btn-sm{padding:3px 9px;font-size:.72rem}

    /* ── Modals ──────────────────────────────────────────── */
    .modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:200;justify-content:center;align-items:center;padding:1rem}
    .modal-bg.open{display:flex}
    .modal{background:#1e293b;border:1px solid #334155;border-radius:14px;padding:1.5rem;width:100%;max-width:500px;max-height:90vh;overflow-y:auto}
    .modal h3{margin-bottom:1rem;font-size:.95rem;color:#e2e8f0}
    .form-group{margin-bottom:.75rem}
    .form-group label{display:block;font-size:.75rem;color:#94a3b8;margin-bottom:3px}
    .form-group input,.form-group select,.form-group textarea{width:100%;background:#0f172a;border:1px solid #334155;color:#e2e8f0;padding:7px 11px;border-radius:7px;font-size:.875rem;outline:none}
    .form-group input:focus,.form-group select:focus{border-color:#38bdf8}
    .form-group textarea{resize:vertical;min-height:70px;font-family:monospace;font-size:.8rem}
    .form-row{display:grid;grid-template-columns:1fr 1fr;gap:.5rem}
    .input-with-btn{display:flex;gap:.5rem}
    .input-with-btn input{flex:1}
    .modal-actions{display:flex;gap:.5rem;justify-content:flex-end;margin-top:1.25rem}
    .url-preview{margin-top:.625rem;padding:.625rem;background:#0f172a;border-radius:7px;font-size:.75rem;color:#94a3b8;line-height:1.6}
    .url-preview code{color:#e2e8f0;word-break:break-all;display:block;margin-top:3px}
    .info-box{padding:.625rem .875rem;border-radius:7px;font-size:.75rem;line-height:1.6;margin-bottom:.75rem}
    .info-box.warn{background:#78350f22;border:1px solid #78350f55;color:#fcd34d}
    .info-box.info{background:#0f346022;border:1px solid #1e3a8a;color:#7dd3fc}
    .info-box.tip{background:#05291622;border:1px solid #166534;color:#86efac}

    /* ── Tabs ────────────────────────────────────────────── */
    .tab-bar{display:flex;gap:.25rem;margin-bottom:.75rem;border-bottom:1px solid #334155}
    .tab{padding:5px 12px;font-size:.78rem;cursor:pointer;border-radius:7px 7px 0 0;color:#94a3b8;background:transparent;border:none}
    .tab.active{background:#334155;color:#e2e8f0}
    .tab-panel{display:none}
    .tab-panel.active{display:block}

    /* ── Misc ────────────────────────────────────────────── */
    .empty-state{text-align:center;padding:3rem 1rem;color:#64748b}
    .toast{position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;padding:.625rem 1rem;border-radius:9px;font-weight:600;font-size:.82rem;transition:opacity .35s;pointer-events:none}
    .lock-pill{font-size:.65rem;padding:2px 7px;border-radius:999px;font-weight:600}
    .lock-on{background:#78350f;color:#fcd34d}
    .lock-off{background:#166534;color:#86efac}
    .hint{font-size:.7rem;color:#64748b;margin-top:3px;line-height:1.4}

    /* ═══════════════════════════════════════════════════════
       Config table — inline edit + OCPP DB
    ═══════════════════════════════════════════════════════ */
    .cfg-table{width:100%;border-collapse:collapse;font-size:.77rem}
    .cfg-table th{text-align:left;padding:5px 7px;color:#64748b;font-weight:600;border-bottom:2px solid #334155;white-space:nowrap;position:sticky;top:0;background:#1e293b;z-index:1}
    .cfg-table td{padding:4px 7px;border-bottom:1px solid #1e293b;vertical-align:middle}
    .cfg-table tr:hover td{background:#0f172a55}

    /* Cellules */
    .cfg-key{color:#94a3b8;font-family:monospace;white-space:nowrap;max-width:100px;overflow:hidden;text-overflow:ellipsis}
    .cfg-val{font-family:monospace;color:#38bdf8;min-width:90px;cursor:pointer;border-radius:4px;padding:2px 4px;transition:background .15s}
    .cfg-val:hover{background:#1e3a5f}
    .cfg-val.ro{color:#64748b;cursor:default}
    .cfg-val.ro:hover{background:transparent}
    .cfg-ocpp{color:#a78bfa;font-size:.71rem;max-width:170px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .cfg-desc{color:#94a3b8;font-size:.70rem;max-width:230px;line-height:1.35}
    .cfg-hint{font-size:.67rem;color:#475569;max-width:130px;line-height:1.3}
    .cfg-ro-icon{text-align:center;color:#64748b;font-size:.7rem}
    .cfg-stat{min-width:88px;text-align:center}

    /* Badges statut */
    .sbadge{display:inline-block;padding:2px 7px;border-radius:10px;font-size:.67rem;font-weight:700;white-space:nowrap}
    .sbadge.accepted{background:#16a34a22;color:#4ade80;border:1px solid #16a34a}
    .sbadge.rejected{background:#dc262622;color:#f87171;border:1px solid #dc2626}
    .sbadge.notsupported{background:#d9770622;color:#fb923c;border:1px solid #d97706}
    .sbadge.rebootrequired{background:#7c3aed22;color:#c4b5fd;border:1px solid #7c3aed}
    .sbadge.pending{background:#0ea5e922;color:#38bdf8;border:1px solid #0ea5e9;animation:pulse .9s infinite}

    /* Éditeur inline */
    .inline-editor{display:flex;gap:4px;align-items:center;flex-wrap:nowrap}
    .inline-editor input,.inline-editor select{font-family:monospace;font-size:.77rem;background:#0f172a;color:#38bdf8;border:1px solid #0ea5e9;border-radius:4px;padding:2px 5px;outline:none}
    .inline-editor input{min-width:70px;max-width:150px}
    .inline-editor select{max-width:200px}
    .ie-save{background:#0ea5e9;color:#fff;border:none;border-radius:4px;padding:2px 8px;cursor:pointer;font-size:.71rem;font-weight:700;white-space:nowrap}
    .ie-save:hover{background:#0284c7}
    .ie-cancel{background:#334155;color:#94a3b8;border:none;border-radius:4px;padding:2px 6px;cursor:pointer;font-size:.71rem}
    .ie-cancel:hover{background:#475569;color:#fff}

    /* Chips CSV */
    .csv-chips{display:flex;flex-wrap:wrap;gap:3px;margin-top:3px;max-width:230px}
    .csv-chip{display:inline-flex;align-items:center;background:#1e293b;border:1px solid #334155;border-radius:3px;padding:1px 5px;font-size:.63rem;color:#94a3b8;cursor:pointer;transition:all .1s;white-space:nowrap}
    .csv-chip.on{background:#0c4a6e;border-color:#0ea5e9;color:#38bdf8}
    .csv-chip:hover{border-color:#64748b}

    @keyframes pulse{0%,100%{opacity:1}50%{opacity:.45}}
  </style>
</head>
<body>

<!-- ══════════════════════════════════════════════════════
     Header
══════════════════════════════════════════════════════ -->
<header>
  <h1>&#9889; OCPP Dashboard</h1>
  <div class="header-right">
    <span id="ws-status" class="badge b-offline">&#9679; Déconnecté</span>
    <button class="btn btn-add" onclick="openModal('add-modal')">+ Ajouter une borne</button>
  </div>
</header>

<main>

  <!-- Statistiques globales -->
  <div class="stats-grid">
    <div class="stat-card"><div class="val" id="s-total">{{ stats.total_chargers }}</div><div class="lbl">Bornes enregistrées</div></div>
    <div class="stat-card"><div class="val" id="s-conn">{{ connected_chargers|length }}</div><div class="lbl">Connectées</div></div>
    <div class="stat-card"><div class="val" id="s-active">{{ stats.active_sessions }}</div><div class="lbl">Sessions actives</div></div>
    <div class="stat-card"><div class="val" id="s-energy">{{ stats.total_energy_kwh }}</div><div class="lbl">kWh livrés</div></div>
  </div>

  <!-- Graphique puissance -->
  <div class="chart-card">
    <div class="section-title" style="margin-bottom:.75rem">Puissance temps réel (W)</div>
    <canvas id="powerChart"></canvas>
  </div>

  <!-- Cartes bornes -->
  <div class="section-title">Bornes de recharge</div>
  <div class="chargers-grid" id="chargers-grid">
    {% for charger in chargers %}
    {% set connected = charger.id in connected_chargers %}
    <div class="charger-card {% if connected %}connected{% endif %}" id="card-{{ charger.id }}">

      <div class="ch-header">
        <div>
          <div class="ch-id">
            {{ charger.id }}
            {% if charger.boot_lock %}
            <span class="lock-pill lock-on">&#128274; Verrouillage auto</span>
            {% else %}
            <span class="lock-pill lock-off">&#128275; Démarrage libre</span>
            {% endif %}
          </div>
          <div class="ch-meta">{{ charger.manufacturer or '—' }} · {{ charger.model or '—' }} · {{ charger.ocpp_protocol }}</div>
          {% if charger.ip_address %}<div class="ch-ip">{{ charger.ip_address }}</div>{% endif %}
          <div class="ch-cfg">
            {% if charger.default_max_amps %}Courant max : {{ charger.default_max_amps | int }} A{% else %}Courant : illimité{% endif %}
          </div>
        </div>
        <span class="badge b-{{ charger.status.value.lower() }}" id="status-{{ charger.id }}">{{ charger.status.value }}</span>
      </div>

      <div class="conn-bar {% if connected %}on{% else %}off{% endif %}" id="connbar-{{ charger.id }}">
        <span class="conn-dot {% if connected %}on{% else %}off{% endif %}" id="dot-{{ charger.id }}"></span>
        <span id="connlbl-{{ charger.id }}">{% if connected %}WebSocket connecté{% else %}Hors ligne — commandes indisponibles{% endif %}</span>
      </div>

      <div class="metrics-grid">
        <div class="metric-box" id="powerbox-{{ charger.id }}">
          <div class="metric-lbl">Puissance</div>
          <div class="metric-val" id="m-power-{{ charger.id }}" style="color:#38bdf8">— W</div>
          <div class="metric-sub" id="m-current-{{ charger.id }}"></div>
        </div>
        <div class="metric-box">
          <div class="metric-lbl">Session</div>
          <div class="metric-val" id="m-session-{{ charger.id }}" style="color:#34d399">— kWh</div>
          <div class="metric-sub" id="m-voltage-{{ charger.id }}"></div>
        </div>
      </div>

      <div class="connectors" id="connectors-{{ charger.id }}">
        {% for c in charger.connectors if c.connector_id > 0 %}
        <div class="connector">
          <div class="cl">Connecteur {{ c.connector_id }}</div>
          <div class="cv" id="cs-{{ charger.id }}-{{ c.connector_id }}">{{ c.status.value }}</div>
        </div>
        {% else %}
        <div class="connector"><div class="cl">En attente de connexion</div></div>
        {% endfor %}
      </div>

      <div class="total-badge" id="total-{{ charger.id }}">Total livré : — kWh</div>
      <div class="tx-info" id="tx-{{ charger.id }}">Aucune session active</div>
      <div class="hb-time" id="hb-{{ charger.id }}">
        Heartbeat : {% if charger.last_heartbeat %}{{ charger.last_heartbeat.strftime('%H:%M:%S') }}{% else %}—{% endif %}
      </div>

      <div class="actions">
        <button class="btn btn-start"   id="btn-start-{{ charger.id }}"   onclick="openStartModal('{{ charger.id }}')"  {% if not connected %}disabled{% endif %}>&#9654; Démarrer</button>
        <button class="btn btn-stop"    id="btn-stop-{{ charger.id }}"    onclick="openStopModal('{{ charger.id }}')"   {% if not connected %}disabled{% endif %}>&#9646; Arrêter</button>
        <button class="btn btn-cut btn-sm"     id="btn-cut-{{ charger.id }}"     onclick="openCutModal('{{ charger.id }}')"      {% if not connected %}disabled{% endif %}>&#9889; Couper charge</button>
        <button class="btn btn-restore btn-sm" id="btn-restore-{{ charger.id }}" onclick="openRestoreModal('{{ charger.id }}')"  {% if not connected %}disabled{% endif %}>&#9889; Rétablir charge</button>
      </div>

      <div class="actions-row2">
        <button class="btn btn-avail btn-sm"   id="btn-avail-{{ charger.id }}"   onclick="setAvail('{{ charger.id }}',true)"   {% if not connected %}disabled{% endif %}>&#10003; Dispo</button>
        <button class="btn btn-unavail btn-sm" id="btn-unavail-{{ charger.id }}" onclick="setAvail('{{ charger.id }}',false)"  {% if not connected %}disabled{% endif %}>&#8856; Hors service</button>
        <button class="btn btn-unlock btn-sm"  id="btn-unlock-{{ charger.id }}"  onclick="unlock('{{ charger.id }}')"          {% if not connected %}disabled{% endif %}>&#128275; Unlock</button>
        <button class="btn btn-reset btn-sm"   id="btn-reset-{{ charger.id }}"   onclick="doReset('{{ charger.id }}')"         {% if not connected %}disabled{% endif %}>&#8635; Reset</button>
        <button class="btn btn-cfg btn-sm"     id="btn-cfg-{{ charger.id }}"
          onclick="openCfgModal('{{ charger.id }}','{{ charger.manufacturer or '' }}','{{ charger.model or '' }}')"
          {% if not connected %}disabled{% endif %}>&#9881; Config</button>
        <button class="btn btn-edit btn-sm"
          onclick="openEditModal('{{ charger.id }}','{{ charger.boot_lock|lower }}','{{ charger.default_max_amps or '' }}')">&#9998; Éditer</button>
      </div>

    </div>
    {% else %}
    <div class="empty-state">
      <p>Aucune borne enregistrée.</p>
      <button class="btn btn-add" style="margin-top:1rem" onclick="openModal('add-modal')">+ Ajouter une borne</button>
    </div>
    {% endfor %}
  </div>

</main>

<!-- ══════════════════════════════════════════════════════
     Modal — Démarrer une session
══════════════════════════════════════════════════════ -->
<div class="modal-bg" id="start-modal">
  <div class="modal">
    <h3>&#9654; Démarrer une session</h3>
    <input type="hidden" id="start-cid">
    <div class="form-group"><label>Borne</label><input type="text" id="start-cid-lbl" disabled></div>
    <div class="form-row">
      <div class="form-group">
        <label>Connecteur</label>
        <input type="number" id="start-conn" value="1" min="1" max="8">
      </div>
      <div class="form-group">
        <label>Badge / ID Tag</label>
        <input type="text" id="start-tag" value="DASHBOARD">
      </div>
    </div>
    <div class="form-group">
      <label>Limite courant (A) — laisser vide = défaut de la borne</label>
      <input type="number" id="start-amps" placeholder="ex: 24" min="6" max="48">
      <div class="hint" id="start-amps-hint"></div>
    </div>
    <div class="modal-actions">
      <button class="btn btn-cancel" onclick="closeModals()">Annuler</button>
      <button class="btn btn-start" onclick="submitStart()">Démarrer</button>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════
     Modal — Arrêter une session
══════════════════════════════════════════════════════ -->
<div class="modal-bg" id="stop-modal">
  <div class="modal">
    <h3>&#9646; Arrêter une session</h3>
    <input type="hidden" id="stop-cid">
    <div class="form-group"><label>Borne</label><input type="text" id="stop-cid-lbl" disabled></div>
    <div class="info-box info">
      <strong>Transaction ID</strong> — numéro unique assigné au démarrage de la session.
      Utilisez le bouton <strong>🔍 Détecter</strong> pour le trouver automatiquement.
    </div>
    <div class="form-group">
      <label>Transaction ID</label>
      <div class="input-with-btn">
        <input type="number" id="stop-txid" placeholder="ex: 7" min="1">
        <button class="btn btn-detect btn-sm" onclick="detectTxId()" type="button">&#128269; Détecter</button>
      </div>
      <div class="hint" id="stop-tx-hint">Cliquez sur Détecter pour trouver la session active.</div>
    </div>
    <div class="form-group">
      <label>Verrouiller après l'arrêt</label>
      <select id="stop-lock">
        <option value="true">Oui — évite redémarrage automatique (recommandé)</option>
        <option value="false">Non — la borne peut redémarrer si câble branché</option>
      </select>
    </div>
    <div class="info-box warn">
      &#9888; Si le véhicule reste branché et redémarre quand même, utilisez <strong>⚡ Couper charge</strong>.
    </div>
    <div class="modal-actions">
      <button class="btn btn-cancel" onclick="closeModals()">Annuler</button>
      <button class="btn btn-stop" onclick="submitStop()">Arrêter la session</button>
    </div>
  </div>
</div>

