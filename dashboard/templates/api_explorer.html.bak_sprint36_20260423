// Refresh chargers every 30s (status peut changer)
setInterval(()=>{
  fetch('/api/chargers/').then(r=>r.json()).then(list=>{
    if(!Array.isArray(list))return;
    STATE.chargers=list;
    const sel=document.getElementById('charger-select');
    const cur=sel.value;
    sel.innerHTML=list.map(c=>{
      const online=(c.status||'').toLowerCase()!=='offline';
      const dot=online?'●':'○';
      return `<option value="${escapeHtml(c.id)}">${dot} ${escapeHtml(c.id)} — ${escapeHtml(c.status||'?')}</option>`;
    }).join('');
    if(list.find(c=>c.id===cur))sel.value=cur;
    updateChargerStatus();
  }).catch(()=>{});
},30000);
