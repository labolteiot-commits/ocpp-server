VEHICLE_PRESENT_STATUSES = {"Charging","Preparing","Finishing","SuspendedEV","SuspendedEVSE"}


class ActionsMixin:
    # ── RemoteStart (profile-driven, séquence unifiée) ────────────────────────
    async def remote_start_transaction(self, connector_id, id_tag, charging_profile=None, max_amps=None):
        # Lever le verrou serveur — l'opérateur démarre manuellement
        self._server_lock_active = False
        if self._remote_start_lock.locked():
            log.warning("RemoteStart ignoré — lock",id=self.id); return False
        async with self._remote_start_lock:
            try:
                amps=max_amps if max_amps is not None else self._default_max_amps
                return await self._do_remote_start(connector_id,amps,id_tag,charging_profile)
            except Exception as e:
                log.error("RemoteStart failed",id=self.id,error=str(e)); return False
    # ── Commandes publiques ────────────────────────────────────────────────────
    async def remote_stop_transaction(self, transaction_id, lock=True):
        try:
            r=await self.call(call.RemoteStopTransaction(transaction_id=transaction_id))
            success=r.status==RemoteStartStopStatus.accepted
            if success and lock: asyncio.create_task(self._lock_after_stop())
            return success
        except Exception as e: log.error("RemoteStop failed",id=self.id,error=str(e)); return False
    async def reset(self, reset_type="Soft"):
        try: r=await self.call(call.Reset(type=ResetType(reset_type))); return r.status==ResetStatus.accepted
        except: return False
    async def clear_cache(self):
        try:
            from ocpp.v16.enums import ClearCacheStatus
            r=await self.call(call.ClearCache()); return r.status==ClearCacheStatus.accepted
        except: return False
    async def get_configuration(self, keys=None):
        try:
            r=await self._safe_call(call.GetConfiguration(key=keys or []),context="GetConfiguration")
            if r:
                for item in r.configuration_key or []: self._config_cache[item["key"]]=item.get("value","")
                return r.configuration_key or []
            return []
        except: return []
    async def change_configuration(self, key, value):
        try:
            r=await self._safe_call(call.ChangeConfiguration(key=key,value=value),context=f"ChangeConfiguration {key}")
            if r and r.status=="Accepted": self._config_cache[key]=value
            return r.status if r else "Failed"
        except: return "Failed"
    async def set_charging_profile(self, connector_id, profile):
        try:
            r=await self._safe_call(call.SetChargingProfile(connector_id=connector_id,cs_charging_profiles=profile),context="SetChargingProfile")
            status = r.status if r else "Failed"
            if status == "Accepted":
                await self._persist_profile_snapshot(connector_id, profile)
                amps = self._extract_limit_amps(profile)
                if amps is not None:
                    self._scheduler_applied_amps = amps
            return status
        except: return "Failed"
    async def clear_charging_profile(
        self,
        connector_id: int | None = 0,
        profile_id: int | None = None,
    ) -> str:
        """A8 — ClearChargingProfile + invalidation du snapshot persisté.

        Sans cette invalidation, A9 ré-appliquerait au boot un profil que
        l'opérateur vient d'effacer côté borne → incohérence silencieuse.
        """
        try:
            kwargs: dict = {}
            if connector_id is not None:
                kwargs["connector_id"] = connector_id
            if profile_id is not None:
                kwargs["id"] = profile_id
            r = await self._safe_call(
                call.ClearChargingProfile(**kwargs),
                context="ClearChargingProfile",
            )
            status = r.status if r else "Failed"
            if status == "Accepted":
                # connector_id=0 dans OCPP signifie "toute la borne" → passer None au helper
                # pour matcher tous les connecteurs, sinon on ne matche que connector_id==0
                # (qui ne correspond à aucun snapshot réel : on persiste sur conn 0 ou 1).
                target_conn = None if (connector_id == 0 or connector_id is None) else connector_id
                await self._expire_profile_snapshots(
                    connector_id=target_conn,
                    profile_id=profile_id,
                )
            log.info("ClearChargingProfile",
                     id=self.id, connector_id=connector_id,
                     profile_id=profile_id, status=status)
            return status
        except Exception as e:
            log.warning("clear_charging_profile failed", id=self.id, error=str(e))
            return "Failed"
    async def set_available(self, connector_id):
        try:
            r=await self._safe_call(call.ChangeAvailability(connector_id=connector_id,type=AvailabilityType.operative),context="set_available")
            return r is not None and r.status in ("Accepted","Scheduled")
        except: return False
    async def set_unavailable(self, connector_id):
        try:
            r=await self._safe_call(call.ChangeAvailability(connector_id=connector_id,type=AvailabilityType.inoperative),context="set_unavailable")
            return r is not None and r.status in ("Accepted","Scheduled")
        except: return False
    async def unlock_connector(self, connector_id):
        try: r=await self.call(call.UnlockConnector(connector_id=connector_id)); return r.status
        except: return "Failed"
    async def trigger_message(self, message, connector_id=None):
        try:
            kw={"requested_message":MessageTrigger(message)}
            if connector_id is not None: kw["connector_id"]=connector_id
            r=await self._safe_call(call.TriggerMessage(**kw),context=f"TriggerMessage {message}")
            return r.status if r else "Failed"
        except: return "Failed"
    async def send_local_list(self, list_version, update_type, local_auth_list):
        try:
            r=await self._safe_call(call.SendLocalList(list_version=list_version,update_type=update_type,local_authorization_list=local_auth_list),context="SendLocalList")
            return r.status if r else "Failed"
        except: return "Failed"
    async def data_transfer(self, vendor_id, message_id="", data=""):
        """Sprint 28 A7 — DataTransfer sortant (serveur → borne), avec audit log."""
        status = None
        response_data = None
        try:
            r = await self._safe_call(
                call.DataTransfer(vendor_id=vendor_id, message_id=message_id, data=data),
                context="DataTransfer",
            )
            if r is not None:
                status = getattr(r, "status", None)
                response_data = getattr(r, "data", None)
        except Exception:
            status = "Error"
        # Audit log (best-effort)
        try:
            import json as _json
            data_str = data if isinstance(data, str) else _json.dumps(data)
            async with AsyncSessionLocal() as db:
                db.add(DataTransferLog(
                    charger_id=self.id, direction="out",
                    vendor_id=vendor_id, message_id=message_id or None,
                    data=data_str, response=str(status) if status else None,
                    timestamp=datetime.now(timezone.utc),
                ))
                await db.commit()
        except Exception as e:
            log.warning("data_transfer persist failed",
                        id=self.id, vendor=vendor_id, error=str(e))
        return response_data
    async def get_diagnostics(
        self,
        location: str,
        retries: int | None = None,
        retry_interval: int | None = None,
        start_time: str | None = None,
        stop_time: str | None = None,
    ) -> dict:
        """Déclenche GetDiagnostics OCPP 1.6J §6.8 + persiste la demande.

        La borne répond avec un `file_name` optionnel. Le suivi d'upload
        se fait ensuite via les DiagnosticsStatusNotification entrantes
        (Idle → Uploading → Uploaded ou UploadFailed).
        """
        kwargs: dict = {"location": location}
        if retries is not None:
            kwargs["retries"] = retries
        if retry_interval is not None:
            kwargs["retry_interval"] = retry_interval
        if start_time:
            kwargs["start_time"] = start_time
        if stop_time:
            kwargs["stop_time"] = stop_time

        filename = None
        try:
            resp = await self._safe_call(call.GetDiagnostics(**kwargs),
                                          context="GetDiagnostics")
            if resp is not None:
                filename = getattr(resp, "file_name", None)
        except Exception as e:
            log.warning("GetDiagnostics failed", id=self.id, error=str(e))

        # Persistance best-effort — même si la borne n'a pas répondu
        req_id = None
        try:
            async with AsyncSessionLocal() as db:
                def _parse_ts(s):
                    if not s:
                        return None
                    try:
                        return datetime.fromisoformat(s.replace("Z", "+00:00"))
                    except Exception:
                        return None
                req = DiagnosticsRequest(
                    charger_id=self.id,
                    location=location,
                    retries=retries or 0,
                    retry_interval=retry_interval,
                    start_time=_parse_ts(start_time),
                    stop_time=_parse_ts(stop_time),
                    requested_at=datetime.now(timezone.utc),
                    filename_returned=filename,
                    status="Requested",
                )
                db.add(req)
                await db.commit()
                await db.refresh(req)
                req_id = req.id
        except Exception as e:
            log.warning("DiagnosticsRequest persist failed",
                        id=self.id, error=str(e))

        log.info("GetDiagnostics envoyé",
                 id=self.id, location=location, filename=filename, req_id=req_id)
        return {"request_id": req_id, "filename": filename}
    async def update_firmware(
        self,
        location: str,
        retrieve_date,
        retries: int | None = None,
        retry_interval: int | None = None,
    ) -> str:
        """Déclenche UpdateFirmware OCPP 1.6J §6.19.

        `retrieve_date` peut être un datetime ou une string ISO. La réponse
        CALLRESULT est vide (pas de champ) — on retourne juste 'Accepted'
        si l'appel n'a pas levé d'exception, sinon 'Failed:<err>'.
        """
        # Normalisation retrieve_date : la lib ocpp attend une ISO string
        if hasattr(retrieve_date, "isoformat"):
            retrieve_str = retrieve_date.isoformat()
        else:
            retrieve_str = str(retrieve_date)

        kwargs: dict = {"location": location, "retrieve_date": retrieve_str}
        if retries is not None:
            kwargs["retries"] = retries
        if retry_interval is not None:
            kwargs["retry_interval"] = retry_interval

        try:
            await self._safe_call(call.UpdateFirmware(**kwargs),
                                   context="UpdateFirmware")
            log.info("UpdateFirmware envoyé",
                     id=self.id, location=location, retrieve=retrieve_str,
                     retries=retries, retry_interval=retry_interval)
            return "Accepted"
        except Exception as e:
            log.warning("UpdateFirmware failed", id=self.id, error=str(e))
            return f"Failed:{str(e)[:50]}"
    async def set_expected_config(self, key: str, value: str) -> str:
        """Force la valeur attendue pour une clé + push ChangeConfiguration.

        UPSERT expected_value=value. Sert aux sprints futurs (UI de config).
        """
        try:
            status = await self.change_configuration(key, value)
        except Exception as e:
            log.warning("set_expected_config ChangeConfiguration failed",
                        id=self.id, key=key, error=str(e))
            status = "Failed"

        try:
            async with AsyncSessionLocal() as db:
                r = await db.execute(
                    select(ConfigSnapshot).where(
                        ConfigSnapshot.charger_id == self.id,
                        ConfigSnapshot.key == key,
                    )
                )
                snap = r.scalar_one_or_none()
                now = datetime.now(timezone.utc)
                if snap is None:
                    db.add(ConfigSnapshot(
                        charger_id=self.id, key=key,
                        expected_value=value,
                        observed_value=value if status == "Accepted" else None,
                        readonly=False, drift_count=0,
                        captured_at=now,
                        last_heal_at=now if status == "Accepted" else None,
                    ))
                else:
                    snap.expected_value = value
                    if status == "Accepted":
                        snap.observed_value = value
                        snap.last_heal_at = now
                    snap.captured_at = now
                await db.commit()
        except Exception as e:
            log.warning("set_expected_config persist failed",
                        id=self.id, key=key, error=str(e))
        return status
    async def set_current_limit(self, amps: float) -> str:
        """
        Change le courant de charge immédiatement selon le profil fabricant.

        TechnoVE / bornes avec use_tx_default_profile=True :
          - Session OCPP active → TxProfile avec transaction_id (effet immédiat)
          - Session locale (synthétique, pas de TX OCPP) → TxDefaultProfile +
            cycle Inoperative/Operative pour forcer l'application
        Générique :
          - ChargePointMaxProfile sur connector 0
        """
        p = self.profile
        use_tx = p.use_tx_default_profile or self._is_technove

        if use_tx:
            active_tx_ids = [tid for tid in self._active_transactions if tid > 0]

            if active_tx_ids:
                # Session OCPP active → TxProfile + transaction_id (effet immédiat)
                tx_id = active_tx_ids[0]
                profile = {
                    "charging_profile_id":      98,
                    "stack_level":              1,
                    "charging_profile_purpose": "TxProfile",
                    "charging_profile_kind":    "Absolute",
                    "transaction_id":           tx_id,
                    "charging_schedule": {
                        "charging_rate_unit":       "A",
                        "charging_schedule_period": [{"start_period": 0, "limit": amps}],
                    },
                }
                status = await self.set_charging_profile(1, profile)
                log.info("set_current_limit — TxProfile (session OCPP active)",
                         id=self.id, amps=amps, tx_id=tx_id, status=status)
                return status

            else:
                # Pas de session OCPP → TxDefaultProfile
                profile = {
                    "charging_profile_id":      99,
                    "stack_level":              0,
                    "charging_profile_purpose": "TxDefaultProfile",
                    "charging_profile_kind":    "Absolute",
                    "charging_schedule": {
                        "charging_rate_unit":       "A",
                        "charging_schedule_period": [{"start_period": 0, "limit": amps}],
                    },
                }
                status = await self.set_charging_profile(1, profile)
                log.info("set_current_limit — TxDefaultProfile (pas de session OCPP)",
                         id=self.id, amps=amps, status=status)

                # Cycle Inop/Op pour forcer l'application immédiate du nouveau profil.
                # Skip si connecteur en Preparing/Charging (TechnoVE reboot sinon).
                if status == "Accepted" and amps > 0:
                    if self._connector1_status not in {"Preparing", "Charging", "SuspendedEV"}:
                        await asyncio.sleep(0.5)
                        try:
                            await self.call(call.ChangeAvailability(
                                connector_id=1, type=AvailabilityType.inoperative,
                            ))
                            await asyncio.sleep(1.0)
                            await self.call(call.ChangeAvailability(
                                connector_id=1, type=AvailabilityType.operative,
                            ))
                            log.info("set_current_limit — cycle Inop/Op appliqué",
                                     id=self.id, amps=amps)
                        except Exception as e:
                            log.warning("set_current_limit — cycle Inop/Op échoué",
                                        id=self.id, error=str(e))
                return status
        else:
            # Générique : ChargePointMaxProfile sur connector 0
            profile = {
                "charging_profile_id":      99,
                "stack_level":              9,
                "charging_profile_purpose": "ChargePointMaxProfile",
                "charging_profile_kind":    "Absolute",
                "charging_schedule": {
                    "charging_rate_unit":       "A",
                    "charging_schedule_period": [{"start_period": 0, "limit": amps}],
                },
            }
            status = await self.set_charging_profile(0, profile)
            log.info("set_current_limit — ChargePointMaxProfile",
                     id=self.id, amps=amps, status=status)
            return status
    async def stop_charging(self, lock: bool = True) -> dict:
        """
        Arrête la charge de façon fiable pour TechnoVE et bornes génériques.

        Séquence multi-étapes :
          1. set_current_limit(0) — coupe le courant physiquement (immédiat)
          2. RemoteStopTransaction si session OCPP active
          3. ChangeAvailability(Inoperative) si lock=True
          4. _server_lock_active=True + boot_lock=True en DB si lock=True
             → survit aux reboots TechnoVE (elle ne redémarre pas la charge)
        """
        results = []

        # Étape 1 : couper le courant via profil
        try:
            cut_status = await self.set_current_limit(0)
            results.append(f"set_limit(0)={cut_status}")
        except Exception as e:
            results.append(f"set_limit(0)=err:{str(e)[:30]}")
            log.warning("stop_charging — couper courant échoué", id=self.id, error=str(e))

        await asyncio.sleep(1)

        # Étape 2 : RemoteStopTransaction si session OCPP active
        active_tx_ids = [tid for tid in self._active_transactions if tid > 0]
        if active_tx_ids:
            tx_id = active_tx_ids[0]
            try:
                resp = await self.call(call.RemoteStopTransaction(transaction_id=tx_id))
                results.append(f"RemoteStop(tx={tx_id})={resp.status}")
                log.info("stop_charging — RemoteStopTransaction",
                         id=self.id, tx_id=tx_id, status=resp.status)
            except Exception as e:
                results.append(f"RemoteStop(tx={tx_id})=err:{str(e)[:30]}")
                log.warning("stop_charging — RemoteStop échoué", id=self.id, error=str(e))
            await asyncio.sleep(2)

        # Étape 3 : Inoperative pour bloquer tout redémarrage
        if lock:
            try:
                resp = await self.call(call.ChangeAvailability(
                    connector_id=1, type=AvailabilityType.inoperative,
                ))
                results.append(f"Inop={resp.status}")
                log.info("stop_charging — ChangeAvailability Inoperative",
                         id=self.id, status=resp.status)
            except Exception as e:
                results.append(f"Inop=err:{str(e)[:30]}")
                log.warning("stop_charging — ChangeAvail Inop échoué", id=self.id, error=str(e))

        # Étape 4 : verrou serveur + persistance DB
        if lock:
            self._server_lock_active = True
            self._boot_lock = True
            try:
                async with AsyncSessionLocal() as db:
                    await db.execute(
                        update(Charger).where(Charger.id == self.id)
                        .values(boot_lock=True)
                    )
                    await db.commit()
                results.append("boot_lock=True(DB)")
                log.info("stop_charging — verrou persisté en DB", id=self.id)
            except Exception as e:
                results.append(f"boot_lock_db=err:{str(e)[:30]}")
                log.warning("stop_charging — persistance verrou échouée",
                            id=self.id, error=str(e))

        self._stop_meter_polling()

        return {"stopped": True, "locked": lock, "method": " | ".join(results)}
    async def on_disconnect(self):
        log.info("Borne déconnectée",id=self.id)
        self._cancel_boot_tasks(); self._stop_meter_polling()
        orphans=list(self._active_transactions.keys())
        if orphans or self._synthetic_session_id:
            try:
                async with AsyncSessionLocal() as db:
                    now=datetime.now(timezone.utc)
                    for txid in orphans:
                        r=await db.execute(select(Session).where(Session.charger_id==self.id,Session.transaction_id==txid,Session.status==SessionStatus.ACTIVE))
                        s=r.scalar_one_or_none()
                        if s: s.stop_time=now; s.stop_reason="EVDisconnected"; s.status=SessionStatus.COMPLETED
                    if self._synthetic_session_id:
                        r=await db.execute(select(Session).where(Session.id==self._synthetic_session_id))
                        s=r.scalar_one_or_none()
                        if s and s.status==SessionStatus.ACTIVE: s.stop_time=now; s.stop_reason="EVDisconnected"; s.status=SessionStatus.COMPLETED
                    await db.commit()
            except Exception as e: log.warning("Disconnect session cleanup failed",id=self.id,error=str(e))
        self._active_transactions.clear(); self._synthetic_session_id=None
        try:
            async with AsyncSessionLocal() as db:
                await db.execute(update(Charger).where(Charger.id==self.id).values(status=ChargerStatus.OFFLINE)); await db.commit()
        except: pass
        await self.server.broadcast_disconnect(self.id)
