def create_app(
    ocpp_server: "OCPPServer",
    scheduler:   "ChargingScheduler | None" = None,
) -> FastAPI:

    app = FastAPI(
        title       = "⚡ OCPP 1.6J Server — Recharge prédictive VE",
        version     = "1.6.31",
        summary     = "Serveur OCPP 1.6J résidentiel + prédictif OBD2 (Québec).",
        description = (
            "## Bienvenue dans le serveur OCPP de la flotte VE\n\n"
            "Ce serveur implémente **OCPP 1.6J** (norme IEC) et coordonne :\n\n"
            "- 🔌 les **bornes de recharge** (TechnoVE, Grizzl-E, simulateur "
            "  `VIRTUAL-001` et toute borne conforme 1.6J) sur le port WebSocket "
            "  **9000** (auth Basic) ;\n"
            "- 🚗 le **prédictif OBD2** (besoin du lendemain en kWh) qui pilote "
            "  le scheduler heures-creuses Hydro-Québec ;\n"
            "- 🛡️ la **whitelist idTag** côté serveur ;\n"
            "- 🔐 la **détection anti-override** (cloud manufacturier qui change "
            "  la config dans le dos du serveur).\n\n"
            "### Profils OCPP supportés\n\n"
            "| Profil | Statut | Sprint |\n"
            "|---|---|---|\n"
            "| Core | ✅ Complet | base |\n"
            "| SmartCharging | ✅ + persistance + replay boot | S23 A9 / S24 A8 |\n"
            "| Reservation | ✅ + auto-expire 60s + consume StartTx | S28 A7 |\n"
            "| FirmwareManagement | ✅ + complétion auto BootNot | S30 A |\n"
            "| RemoteTrigger | ✅ Complet | S26 A3 |\n"
            "| LocalAuthListManagement | ✅ Sprint 31 (endpoints REST) | S31 |\n"
            "| DataTransfer | ✅ in/out + audit `data_transfer_logs` | S28 A7 |\n\n"
            "### Extensions propriétaires\n\n"
            "- **Anti-override config** (S29 Volet D) : boucle 300s + auto-heal\n"
            "- **Anti-override courant** (S30 C) : 3 samples consécutifs > expected + 2A → re-apply\n"
            "- **Whitelist idTag** (S29 Volet A) : table `ocpp_tags`\n\n"
            "### Liens utiles\n\n"
            "- 📚 [Norme OCPP 1.6J](https://www.openchargealliance.org/protocols/ocpp-16/) "
            "(Open Charge Alliance)\n"
            "- 🧪 Borne virtuelle simulée : `VIRTUAL-001` (port 8001 dashboard)\n"
            "- 📖 Schémas DB : `db/models.py`\n\n"
            "**Auth admin** : si les variables d'environnement `OCPP_DASH_USER` "
            "et `OCPP_DASH_PASS` sont définies, toutes les routes admin (sauf "
            "obd2 / tags) requièrent HTTP Basic. Sinon : mode ouvert (warning loggé)."
        ),
        contact      = {
            "name":  "lteiot — Pi prod",
            "url":   "http://192.168.1.210:8000",
        },
        license_info = {
            "name": "Internal — usage privé",
        },
        openapi_tags = TAGS_METADATA,
        docs_url     = "/docs",
        redoc_url    = "/redoc",
    )

    # ── CORS ────────────────────────────────────────────────
    app.add_middleware(
        CORSMiddleware,
        allow_origins     = settings.api.allowed_origins,
        allow_credentials = True,
        allow_methods     = ["*"],
        allow_headers     = ["*"],
    )

    # ── État global ─────────────────────────────────────────
    app.state.ocpp_server = ocpp_server
    app.state.scheduler   = scheduler

    # ── Routers ─────────────────────────────────────────────
    # Sprint 29 Volet C : require_auth appliqué aux routers admin (dashboard,
    # commands, tags). WebSocket (api.websocket) et routes consommées par
    # les bornes OCPP ne sont PAS protégées (bornes passent par WS port 9000
    # avec leur propre Basic auth dans core.ocpp_server._authenticate).
    #
    # Sprint 31 : commands_router n'a plus de `tags=[...]` global — chaque
    # endpoint porte son propre tag de profil OCPP (cf. TAG_* dans commands.py).
    app.include_router(dashboard_router,  prefix="", dependencies=[Depends(require_auth)])
    app.include_router(websocket_router,  prefix="")
    app.include_router(chargers_router,   prefix="/api/chargers",  tags=["Bornes"],            dependencies=[Depends(require_auth)])
    app.include_router(commands_router,   prefix="/api/commands",                              dependencies=[Depends(require_auth)])
    app.include_router(sessions_router,   prefix="/api/sessions",  tags=["Sessions"],          dependencies=[Depends(require_auth)])
    app.include_router(obd2_router,       prefix="/api/obd2",      tags=["OBD2 & Prédictif"])
    app.include_router(tags_router,       prefix="/api/tags",      tags=["Whitelist idTags"])
    # Sprint 30 Volet B — pages admin (HTML), auth HTTP Basic
    app.include_router(admin_ui_router,   prefix="",               tags=["Admin UI"],          dependencies=[Depends(require_auth)])

    @app.on_event("startup")
    async def on_startup():
        log.info("API démarrée", port=settings.api.port)

    @app.on_event("shutdown")
    async def on_shutdown():
        log.info("API arrêtée")

    return app
