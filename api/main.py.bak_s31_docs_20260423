# api/main.py
"""
Factory de l'application FastAPI.
Enregistre tous les routers et configure l'état global (ocpp_server, scheduler).
"""
from __future__ import annotations

from typing import TYPE_CHECKING

from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware

from config import settings
from core.logging import log

# Routes
from api.routes.chargers  import router as chargers_router
from api.routes.commands  import router as commands_router
from api.routes.sessions  import router as sessions_router
from api.routes.dashboard import router as dashboard_router
from api.websocket        import router as websocket_router   # api/websocket.py, pas api/routes/
from api.routes.obd2      import router as obd2_router
# Sprint 29 Volet A — whitelist idTags
from api.routes.tags      import router as tags_router
# Sprint 30 Volet B — pages admin UI (tags / config-drifts / firmware)
from api.routes.admin_ui  import router as admin_ui_router
# Sprint 29 Volet C — HTTP Basic auth (mode ouvert si OCPP_DASH_USER/PASS absents)
from api.security         import require_auth
from fastapi import Depends

if TYPE_CHECKING:
    from core.ocpp_server import OCPPServer
    from core.scheduler   import ChargingScheduler


def create_app(
    ocpp_server: "OCPPServer",
    scheduler:   "ChargingScheduler | None" = None,
) -> FastAPI:

    app = FastAPI(
        title       = settings.app_name,
        version     = "1.0.0",
        description = "Serveur OCPP résidentiel avec prédictif OBD2",
    )

    # ── CORS ────────────────────────────────────────────────
    app.add_middleware(
        CORSMiddleware,
        allow_origins     = settings.api.allowed_origins,
        allow_credentials = True,
        allow_methods     = ["*"],
        allow_headers     = ["*"],
    )

    # ── État global ─────────────────────────────────────────
    app.state.ocpp_server = ocpp_server
    app.state.scheduler   = scheduler

    # ── Routers ─────────────────────────────────────────────
    # Sprint 29 Volet C : require_auth appliqué aux routers admin (dashboard,
    # commands, tags). WebSocket (api.websocket) et routes consommées par
    # les bornes OCPP ne sont PAS protégées (bornes passent par WS port 9000
    # avec leur propre Basic auth dans core.ocpp_server._authenticate).
    app.include_router(dashboard_router,  prefix="", dependencies=[Depends(require_auth)])
    app.include_router(websocket_router,  prefix="")
    app.include_router(chargers_router,   prefix="/api/chargers",  tags=["Bornes"],          dependencies=[Depends(require_auth)])
    app.include_router(commands_router,   prefix="/api/commands",  tags=["Commandes OCPP"],  dependencies=[Depends(require_auth)])
    app.include_router(sessions_router,   prefix="/api/sessions",  tags=["Sessions"],        dependencies=[Depends(require_auth)])
    app.include_router(obd2_router,       prefix="/api/obd2",      tags=["OBD2 & Prédictif"])
    app.include_router(tags_router,       prefix="/api/tags",      tags=["Whitelist idTags"])
    # Sprint 30 Volet B — pages admin (HTML), auth HTTP Basic
    app.include_router(admin_ui_router,   prefix="",              tags=["Admin UI"],        dependencies=[Depends(require_auth)])

    @app.on_event("startup")
    async def on_startup():
        log.info("API démarrée", port=settings.api.port)

    @app.on_event("shutdown")
    async def on_shutdown():
        log.info("API arrêtée")

    return app
