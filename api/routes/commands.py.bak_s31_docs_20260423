# ── Helper ───────────────────────────────────────────────────────────────────

def _get_cp(request: Request, charger_id: str):
    cp = request.app.state.ocpp_server.get_charger(charger_id)
    if not cp:
        raise HTTPException(
            status_code=400,
            detail=f"Borne '{charger_id}' non connectée"
        )
    return cp


# ── Démarrage de charge ───────────────────────────────────────────────────────

@router.post("/remote-start")
async def remote_start(body: RemoteStartRequest, request: Request):
    """Démarre une charge sur la borne."""
    cp = _get_cp(request, body.charger_id)

    # Lever le verrou serveur avant de démarrer manuellement
    cp._server_lock_active = False

    success = await cp.remote_start_transaction(
        connector_id=body.connector_id,
        id_tag=body.id_tag,
        max_amps=body.max_amps,
    )
    if not success:
        raise HTTPException(status_code=400, detail="La borne a refusé le démarrage")
    return {"detail": "Démarrage accepté"}


# ── Arrêt de charge ───────────────────────────────────────────────────────────

@router.post("/remote-stop")
async def remote_stop(
    body: RemoteStopRequest,
    request: Request,
    db: AsyncSession = Depends(get_db),
):
    """
    Arrête la charge de façon fiable.

    Utilise stop_charging() qui effectue une séquence multi-étapes :
    1. SetChargingProfile(limit=0) — coupe le courant physiquement
    2. RemoteStopTransaction si transaction OCPP active
    3. ChangeAvailability(Inoperative) si lock=True
    4. boot_lock=True en DB si lock=True → survit aux reboots

    Pour les sessions synthétiques (transaction_id < 0) : même séquence,
    sans RemoteStopTransaction (pas de transaction OCPP à arrêter).
    """
    cp = _get_cp(request, body.charger_id)

    result = await cp.stop_charging(lock=body.lock)

    log.info("remote_stop — séquence complète",
             charger_id=body.charger_id,
             locked=body.lock,
             method=result.get("method", ""))

    return {
        "detail": "Arrêt effectué" if result["stopped"] else "Arrêt partiel",
        "locked": result["locked"],
        "method": result["method"],
    }


@router.get("/active-transaction/{charger_id}")
async def get_active_transaction(
    charger_id: str,
    db: AsyncSession = Depends(get_db)
):
    """Retourne la transaction active d'une borne (OCPP ou synthétique)."""
    result = await db.execute(
        select(ChargingSession)
        .where(ChargingSession.charger_id == charger_id)
        .where(ChargingSession.status     == SessionStatus.ACTIVE)
        .order_by(desc(ChargingSession.start_time))
        .limit(1)
    )
    session = result.scalar_one_or_none()
    if not session:
        return {"transaction_id": None, "id_tag": None, "start_time": None}
    return {
        "transaction_id": session.transaction_id,
        "id_tag":         session.id_tag,
        "start_time":     session.start_time.isoformat(),
        "meter_start":    session.meter_start,
        "is_synthetic":   session.transaction_id is not None and session.transaction_id < 0,
    }


# ── Disponibilité ─────────────────────────────────────────────────────────────

@router.post("/set-available")
async def set_available(body: AvailabilityRequest, request: Request):
    """
    Remet un connecteur en mode Operative.

    IMPORTANT : lève aussi le verrou serveur (_server_lock_active = False)
    pour que la borne puisse relancer une charge si un véhicule est branché.
    Sans ça, après un arrêt manuel, la borne resterait bloquée même si
    l'opérateur veut relancer manuellement.
    """
    cp = _get_cp(request, body.charger_id)

    # Lever explicitement le verrou serveur
    cp._server_lock_active = False
    cp._boot_lock = False

    # Mettre à jour boot_lock en DB pour que le prochain reboot ne verrouille pas
    try:
        from db.database import AsyncSessionLocal
        async with AsyncSessionLocal() as db:
            from sqlalchemy import update as sa_update
            await db.execute(
                sa_update(Charger).where(Charger.id == body.charger_id)
                .values(boot_lock=False)
            )
            await db.commit()
    except Exception as e:
        log.warning("set_available — mise à jour boot_lock échouée",
                    id=body.charger_id, error=str(e))

    success = await cp.set_available(body.connector_id)
    if not success:
        raise HTTPException(status_code=400, detail="La borne a refusé")
    return {"detail": f"Connecteur {body.connector_id} remis en disponible, verrou levé"}


@router.post("/set-unavailable")
async def set_unavailable(body: AvailabilityRequest, request: Request):
    """
    Met un connecteur en mode Inoperative.

    Note : si une session est en cours, la borne répondra 'Scheduled' et
    passera Inoperative seulement après la fin de la session.
    Pour couper immédiatement, utiliser /set-power-limit avec max_amps=0
    puis /set-unavailable.
    """
    cp = _get_cp(request, body.charger_id)
    success = await cp.set_unavailable(body.connector_id)
    if not success:
        raise HTTPException(status_code=400, detail="La borne a refusé")
    return {"detail": f"Connecteur {body.connector_id} mis hors service"}


@router.post("/unlock")
async def unlock_connector(body: UnlockRequest, request: Request):
    """A6 — Déverrouille mécaniquement un connecteur (§6.30).

    Utile quand le verrou reste coincé après un StopTransaction.
    Réponse typique de la borne : Unlocked / UnlockFailed / NotSupported.
    Le câble est considéré débranché par l'EV-side seulement si le verrou
    cède physiquement — pas une garantie logicielle.
    """
    cp = _get_cp(request, body.charger_id)
    status = await cp.unlock_connector(body.connector_id)
    if status == "Failed":
        raise HTTPException(status_code=400, detail="Déverrouillage échoué")
    return {"detail": f"Connecteur {body.connector_id} déverrouillé", "status": status}


# ── A5 : ChangeAvailability explicite (connector_id=0 = toute la borne) ──────

class ChangeAvailabilityRequest(BaseModel):
    charger_id:   str
    connector_id: int = 0  # 0 = toute la borne (§6.1 OCPP 1.6)
    operative:    bool = True


@router.post("/change-availability")
async def change_availability(body: ChangeAvailabilityRequest, request: Request):
    """A5 — ChangeAvailability explicite conforme OCPP 1.6 §6.1.

    connector_id=0 signifie "toute la borne" (tous les connecteurs).
    Attention : certaines bornes buguées (TechnoVE ancienne) traitent
    connector_id=0 comme connector_id=1. Vérifier dans logs/ocpp_raw/
    la réponse exacte de la borne (Accepted / Rejected / Scheduled).

    `operative=True`  → Operative   (disponible)
    `operative=False` → Inoperative (mise hors service, charge terminée d'abord
    si une session est en cours → status=Scheduled).
    """
    cp = _get_cp(request, body.charger_id)
    if body.operative:
        success = await cp.set_available(body.connector_id)
    else:
        success = await cp.set_unavailable(body.connector_id)
    if not success:
        raise HTTPException(status_code=400, detail="La borne a refusé")
    state = "Operative" if body.operative else "Inoperative"
    scope = "toute la borne" if body.connector_id == 0 else f"connecteur {body.connector_id}"
    return {"detail": f"ChangeAvailability {state} — {scope}"}


