# ── Sprint 30 Volet A : UpdateFirmware flow ──────────────────────────────────

@router.post("/update-firmware")
async def update_firmware(body: UpdateFirmwareRequestBody, request: Request,
                          db: AsyncSession = Depends(get_db)):
    """Déclenche UpdateFirmware OCPP 1.6J §6.19 + persiste la demande.

    `location` est l'URL (HTTP/HTTPS/FTP) où la borne télécharge le firmware.
    `retrieve_date` optionnelle (ISO 8601) — défaut = maintenant + 1 minute.
    Le suivi se fait via FirmwareStatusNotification (status dans DB).
    """
    from datetime import datetime as _dt, timezone as _tz, timedelta as _td

    cp = _get_cp(request, body.charger_id)

    # Parse retrieve_date ou défaut +1 min
    if body.retrieve_date:
        try:
            retrieve_dt = _dt.fromisoformat(body.retrieve_date.replace("Z", "+00:00"))
            if retrieve_dt.tzinfo is None:
                retrieve_dt = retrieve_dt.replace(tzinfo=_tz.utc)
        except Exception as e:
            raise HTTPException(status_code=400,
                                detail=f"retrieve_date invalide: {e}")
    else:
        retrieve_dt = _dt.now(_tz.utc) + _td(minutes=1)

    # Lire version actuelle (pour firmware_version_before)
    charger = await db.get(Charger, body.charger_id)
    current_version = charger.firmware_version if charger else None

    # Persister la demande AVANT l'appel OCPP (audit même si la call échoue)
    fw = FirmwareUpdate(
        charger_id=body.charger_id,
        location=body.location,
        retrieve_date=retrieve_dt,
        retries=body.retries,
        retry_interval=body.retry_interval,
        requested_at=_dt.now(_tz.utc),
        status="Requested",
        firmware_version_before=current_version,
    )
    db.add(fw)
    await db.commit()
    await db.refresh(fw)

    # Appel OCPP UpdateFirmware
    call_status = await cp.update_firmware(
        location=body.location,
        retrieve_date=retrieve_dt,
        retries=body.retries,
        retry_interval=body.retry_interval,
    )

    return {
        "id":                fw.id,
        "status":            fw.status,
        "call_status":       call_status,
        "location":          body.location,
        "retrieve_date":     retrieve_dt.isoformat(),
        "firmware_before":   current_version,
    }


