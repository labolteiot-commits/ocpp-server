# api/routes/commands.py
"""
Routes de commandes OCPP — version corrigée pour TechnoVE et bornes génériques.

CORRECTIONS vs version précédente :
  BUG-A  set_power_limit : utilisait ChargePointMaxProfile sur connector 0
         → TechnoVE l'IGNORE. Maintenant utilise set_current_limit() qui
         choisit TxProfile/TxDefaultProfile/ChargePointMaxProfile selon le profil.
  BUG-B  Validation du courant max AVANT l'envoi (était après → trop tard)
  BUG-C  remote_stop : séquence multi-étapes via stop_charging() au lieu de
         RemoteStopTransaction seul (qui n'arrête pas TechnoVE sans OCPP transaction)
  BUG-D  set_available relance la charge après un arrêt manuel → doit vérifier
         _server_lock_active et reset le verrou intentionnellement
  BUG-E  _lock_after_stop remplacé par stop_charging() qui persiste boot_lock en DB
         pour survivre aux reboots TechnoVE
"""
import asyncio
from fastapi import APIRouter, Depends, HTTPException, Request
from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy import select
from sqlalchemy.orm import selectinload
from sqlalchemy import desc
