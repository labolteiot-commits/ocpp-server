# ── Smart Charging ────────────────────────────────────────────────────────────

@router.post("/set-power-limit")
async def set_power_limit(body: PowerLimitRequest, request: Request):
    """
    Impose une limite de courant immédiate sur la borne.

    BUG-A CORRIGÉ : n'utilise plus ChargePointMaxProfile sur connector 0
    (ignoré par TechnoVE). Utilise set_current_limit() qui choisit la bonne
    stratégie selon le profil fabricant :
      - TechnoVE avec session OCPP : TxProfile + transaction_id (effet immédiat)
      - TechnoVE sans session OCPP : TxDefaultProfile + cycle Inop/Op
      - Générique : ChargePointMaxProfile sur connector 0

    BUG-B CORRIGÉ : validation AVANT l'envoi du profil.
    BUG-C CORRIGÉ : max_amps=0 utilise stop_charging() au lieu de juste
                    un profil 0A qui serait ignoré par TechnoVE.
    """
    cp = _get_cp(request, body.charger_id)

    # ── Validation AVANT envoi (était APRÈS dans l'ancienne version) ──────
    if body.max_amps < 0:
        raise HTTPException(status_code=422, detail="max_amps ne peut pas être négatif")

    if body.max_amps == 0:
        # Arrêt complet — utiliser stop_charging() pour garantir l'effet sur TechnoVE
        result = await cp.stop_charging(lock=True)
        return {
            "detail": "Charge coupée et borne verrouillée",
            "method": result.get("method", ""),
        }

    # Limiter à la capacité physique de la borne
    hw_max = cp._default_max_amps
    if hw_max and body.max_amps > hw_max:
        raise HTTPException(
            status_code=422,
            detail=(
                f"Courant demandé ({body.max_amps:.0f}A) supérieur au maximum configuré "
                f"pour cette borne ({hw_max:.0f}A). "
                f"Modifiez 'Courant max' dans les paramètres si vous voulez dépasser cette limite."
            )
        )

    # ── Appliquer la limite via la méthode profile-aware ──────────────────
    status = await cp.set_current_limit(body.max_amps)

    if status == "Failed":
        raise HTTPException(status_code=400, detail="SetChargingProfile échoué")

    # Lever le verrou serveur si on impose une limite positive
    # (l'opérateur veut que la borne charge, juste à un courant limité)
    if getattr(cp, '_server_lock_active', False):
        cp._server_lock_active = False
        log.info("set_power_limit — verrou serveur levé (limite positive)", id=cp.id)

    return {
        "detail": f"Limite imposée à {body.max_amps}A",
        "status": status,
    }


@router.post("/charging-profile/set")
async def set_charging_profile_endpoint(
    body: ChargingProfileRequest, request: Request
):
    """Définit un profil de charge explicite."""
    cp = _get_cp(request, body.charger_id)

    profile = {
        "charging_profile_id":      1,
        "stack_level":              0,
        "charging_profile_purpose": "TxDefaultProfile",
        "charging_profile_kind":    "Absolute",
        "charging_schedule": {
            "charging_rate_unit":        "A",
            "charging_schedule_period":  [{"start_period": 0, "limit": body.max_amps}],
        },
    }
    if body.duration_seconds:
        profile["charging_schedule"]["duration"] = body.duration_seconds

    status = await cp.set_charging_profile(body.connector_id, profile)
    if status == "Failed":
        raise HTTPException(status_code=400, detail="SetChargingProfile échoué")
    return {"detail": f"Profil de charge {body.max_amps}A appliqué", "status": status}


@router.post("/charging-profile/clear")
async def clear_charging_profile(body: ClearProfileRequest, request: Request):
    """Efface un profil de charge."""
    cp = _get_cp(request, body.charger_id)
    try:
        from ocpp.v16 import call as ocpp_call
        kwargs: dict = {"connector_id": body.connector_id}
        if body.profile_id is not None:
            kwargs["id"] = body.profile_id
        resp = await cp.call(ocpp_call.ClearChargingProfile(**kwargs))
        return {"detail": "Profil effacé", "status": resp.status}
    except Exception as e:
        raise HTTPException(status_code=400, detail=f"ClearChargingProfile échoué: {e}")


@router.get("/composite-schedule/{charger_id}/{connector_id}")
async def get_composite_schedule(
    charger_id: str,
    connector_id: int,
    duration: int = 86400,
    request: Request = None,
):
    """Récupère le planning de charge composite (GetCompositeSchedule)."""
    cp = _get_cp(request, charger_id)
    try:
        from ocpp.v16 import call as ocpp_call
        resp = await cp.call(ocpp_call.GetCompositeSchedule(
            connector_id=connector_id,
            duration=duration,
        ))
        return {
            "status":          resp.status,
            "connector_id":    getattr(resp, "connector_id", connector_id),
            "schedule_start":  getattr(resp, "schedule_start", None),
            "charging_schedule": getattr(resp, "charging_schedule", None),
        }
    except Exception as e:
        raise HTTPException(status_code=400, detail=f"GetCompositeSchedule échoué: {e}")


# ── Réservation ───────────────────────────────────────────────────────────────

@router.post("/reserve")
async def reserve_now(body: ReserveRequest, request: Request):
    """Réserve un connecteur."""
    cp = _get_cp(request, body.charger_id)
    try:
        from ocpp.v16 import call as ocpp_call
        from datetime import datetime, timezone, timedelta
        expiry = body.expiry_date or (
            datetime.now(timezone.utc) + timedelta(hours=1)
        ).isoformat()
        resp = await cp.call(ocpp_call.ReserveNow(
            connector_id=body.connector_id,
            expiry_date=expiry,
            id_tag=body.id_tag,
            reservation_id=1,
        ))
        if resp.status != "Accepted":
            raise HTTPException(status_code=400, detail=f"Réservation refusée: {resp.status}")
        return {"detail": "Réservation acceptée", "status": resp.status}
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=400, detail=f"ReserveNow échoué: {e}")


@router.post("/cancel-reserve")
async def cancel_reserve(body: CancelReserveRequest, request: Request):
    """Annule une réservation."""
    cp = _get_cp(request, body.charger_id)
    try:
        from ocpp.v16 import call as ocpp_call
        resp = await cp.call(ocpp_call.CancelReservation(
            reservation_id=body.reservation_id,
        ))
        return {"detail": "Réservation annulée", "status": resp.status}
    except Exception as e:
        raise HTTPException(status_code=400, detail=f"CancelReservation échoué: {e}")


