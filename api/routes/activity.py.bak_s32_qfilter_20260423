@router.post("/activity/_purge", tags=[TAG_ACTIVITY],
             summary="Purge manuelle des lignes plus vieilles que N jours")
async def purge(days: int = Query(90, ge=1, le=3650)):
    from core.activity_logger import purge_activity
    deleted = await purge_activity(days=days)
    return {"deleted": deleted, "older_than_days": days}


@router.get("/activity/charger/{charger_id}/timeline", tags=[TAG_ACTIVITY],
            summary="Timeline récente d'une borne",
            description="""
Renvoie les N derniers événements d'une borne (défaut 200) sur une fenêtre
optionnelle (défaut 24h). Utile pour la modal "voir l'activité récente"
sur la page borne.
""")
async def charger_timeline(
    charger_id: str,
    hours:      int = Query(24, ge=1, le=720),
    limit:      int = Query(200, ge=1, le=1000),
):
    since = datetime.utcnow() - timedelta(hours=hours)
    async with AsyncSessionLocal() as db:
        # Vérifier que la borne existe (404 si non)
        r = await db.execute(select(Charger).where(Charger.id == charger_id))
        if r.scalar_one_or_none() is None:
            raise HTTPException(404, f"Borne inconnue : {charger_id}")

        r = await db.execute(
            select(ChargerActivityLog)
            .where(ChargerActivityLog.charger_id == charger_id,
                   ChargerActivityLog.timestamp >= since)
            .order_by(desc(ChargerActivityLog.timestamp))
            .limit(limit)
        )
        rows = r.scalars().all()
        return {
            "charger_id": charger_id,
            "hours":      hours,
            "count":      len(rows),
            "items":      [_row_to_dict(row) for row in rows],
        }


@router.get("/activity/{row_id}", tags=[TAG_ACTIVITY],
            summary="Détail d'une ligne + doc du message",
            description="""
Renvoie la ligne complète (payload formaté) ET la documentation FR du
message OCPP correspondant si disponible (jointure OcppMessageDoc.name == action).
""")
async def get_activity_row(row_id: int):
    async with AsyncSessionLocal() as db:
        r = await db.execute(
            select(ChargerActivityLog).where(ChargerActivityLog.id == row_id)
        )
        row = r.scalar_one_or_none()
        if row is None:
            raise HTTPException(404, f"Ligne introuvable : id={row_id}")

        result = _row_to_dict(row)

        if row.action:
            r2 = await db.execute(
                select(OcppMessageDoc).where(OcppMessageDoc.name == row.action)
            )
            doc = r2.scalar_one_or_none()
            if doc:
                result["doc"] = _doc_to_dict(doc)
        return result


# ───────────────────────────────────── Doc messages ─────────────────────────

def _doc_to_dict(doc: OcppMessageDoc) -> dict:
    fields = None
    if doc.fields_fr:
        try:
            fields = json.loads(doc.fields_fr)
        except Exception:
            fields = None
    return {
        "name":           doc.name,
        "direction_norm": doc.direction_norm,
        "profile":        doc.profile,
        "section_norm":   doc.section_norm,
        "summary_fr":     doc.summary_fr,
        "description_fr": doc.description_fr,
        "fields_fr":      fields,
        "triggered_by":   doc.triggered_by,
        "cs_response":    doc.cs_response,
        "updated_at":     doc.updated_at.isoformat() if doc.updated_at else None,
    }


@router.get("/message-docs", tags=[TAG_DOCS],
            summary="Liste de tous les messages OCPP documentés")
async def list_message_docs(
    profile:   Optional[str] = Query(None, description="Filtre par profil OCPP."),
    direction: Optional[str] = Query(None, regex="^(CP→CSMS|CSMS→CP|both)$",
                                      description="Filtre par direction."),
):
    async with AsyncSessionLocal() as db:
        stmt = select(OcppMessageDoc)
        if profile:
            stmt = stmt.where(OcppMessageDoc.profile == profile)
        if direction:
            stmt = stmt.where(OcppMessageDoc.direction_norm == direction)
        stmt = stmt.order_by(OcppMessageDoc.profile, OcppMessageDoc.name)
        r = await db.execute(stmt)
        docs = r.scalars().all()
        return {
            "count": len(docs),
            "items": [_doc_to_dict(d) for d in docs],
        }


@router.get("/message-docs/{action}", tags=[TAG_DOCS],
            summary="Documentation FR détaillée d'une action OCPP",
            description="""
Renvoie la doc complète :
* `summary_fr` (1 phrase)
* `description_fr` (2-4 phrases)
* `fields_fr` ({champ: explication})
* `triggered_by` (quand ce message est émis)
* `cs_response` (réponse standard)
* `section_norm` (référence dans la spec OCPP 1.6J)

Source : seed statique `core/ocpp_message_docs_seed.py` basé sur OCPP 1.6J
Edition 2 (juillet 2017, Open Charge Alliance).
""")
async def get_message_doc(action: str):
    async with AsyncSessionLocal() as db:
        r = await db.execute(
            select(OcppMessageDoc).where(OcppMessageDoc.name == action)
        )
        doc = r.scalar_one_or_none()
        if doc is None:
            raise HTTPException(404,
                f"Pas de documentation pour le message OCPP : {action}")
        return _doc_to_dict(doc)
