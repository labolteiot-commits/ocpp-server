# .env  (ne jamais committer ce fichier)
APP_NAME="Mon Serveur OCPP"
ENVIRONMENT=production

# OCPP WebSocket
OCPP__HOST=0.0.0.0
OCPP__PORT=9000
OCPP__PING_INTERVAL=30
OCPP__WS_PATH=/ocpp

# API REST
API__HOST=0.0.0.0
API__PORT=8000
API__SECRET_KEY=remplace-moi-par-une-vraie-clé-secrète-longue
API__ALLOWED_ORIGINS=["http://192.168.1.100","http://localhost"]

# Base de données
DATABASE__URL=sqlite+aiosqlite:////home/lteiot/ocpp-server/data/ocpp.db
DATABASE__ECHO=false

# OBD2 (désactivé par défaut)
OBD2__ENABLED=false
OBD2__SERVER_URL=http://localhost:8080
OBD2__POLL_INTERVAL=5

# Logs
LOG__LEVEL=INFO
